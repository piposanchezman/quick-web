---
/**
 * Dynamic User Count Component
 * Fetches registered user count from API
 */
---

<div
  id="stat-users"
  class="bg-black/20 p-6 rounded-2xl border border-white/5 hover:border-[#f59e0b]/30 transition-colors text-center"
>
  <!-- Loading -->
  <div id="users-loading" class="animate-pulse">
    <div
      class="text-4xl font-black text-[#f59e0b] mb-2 drop-shadow-[0_0_10px_rgba(245,158,11,0.4)]"
    >
      --k+
    </div>
    <div
      class="text-sm text-gray-400 uppercase tracking-wider font-bold"
      data-i18n="about.users"
    >
    </div>
  </div>

  <!-- Content -->
  <div id="users-content" class="hidden">
    <div
      id="users-count"
      class="text-4xl font-black text-[#f59e0b] mb-2 drop-shadow-[0_0_10px_rgba(245,158,11,0.4)]"
    >
      10k+
    </div>
    <div
      class="text-sm text-gray-400 uppercase tracking-wider font-bold"
      data-i18n="about.users"
    >
    </div>
  </div>
</div>

<script>
  async function fetchUserCount() {
    const loadingEl = document.getElementById("users-loading");
    const contentEl = document.getElementById("users-content");
    const countEl = document.getElementById("users-count");

    try {
      const response = await fetch("/api/users");
      if (!response.ok) throw new Error("Failed to fetch user count");

      const data = await response.json();

      if (countEl) {
        // Format the count
        const count = data.count;
        let displayCount = "";

        if (count >= 1000000) {
          displayCount = `${(count / 1000000).toFixed(1)}M+`;
        } else if (count >= 1000) {
          displayCount = `${Math.floor(count / 1000)}k+`;
        } else {
          displayCount = `${count}+`;
        }

        countEl.textContent = displayCount;
      }

      if (loadingEl) loadingEl.classList.add("hidden");
      if (contentEl) contentEl.classList.remove("hidden");
    } catch (error) {
      console.warn("[UserCount] Fetch failed, using fallback user count.");
      
      // Show fallback
      if (countEl) countEl.textContent = "10k+";
      if (loadingEl) loadingEl.classList.add("hidden");
      if (contentEl) contentEl.classList.remove("hidden");
    }
  }

  document.addEventListener("DOMContentLoaded", () => {
    fetchUserCount();
  });
</script>
